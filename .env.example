PORT=5000
JWT_SECRET=your_strong_jwt_secret_here
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# ─── Dynamic Base URL ─────────────────────────────────────────
# CRITICAL: Set this to your actual public domain in production.
# Used to generate shareable live tracking links like:
#   https://your-domain.com/live/abc123
# For local development: http://localhost:5000
# For Render: https://your-service.onrender.com
# For Railway: https://your-service.railway.app
# If not set, the server auto-detects from request headers (safe fallback).
BASE_URL=https://your-deployed-domain.com

# ─── Turso (Free Cloud SQLite) ────────────────────────────────
# Sign up free at https://turso.tech (GitHub login, no credit card)
# Setup:
#   npm install -g @turso/cli
#   turso auth login
#   turso db create safenex
#   turso db show safenex --url     → copy here
#   turso db tokens create safenex  → copy here
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your_turso_token_here

NODE_ENV=production
